# =====================================================
# Cantinho System — Configuração VPS
# COPIE este arquivo como .env e edite os valores
# IMPORTANTE: nunca compartilhe o .env publicamente
# =====================================================

# ── Banco de dados ──
POSTGRES_DB=cantinho
POSTGRES_USER=cantinho
POSTGRES_PASSWORD=__GERAR_SENHA_FORTE_32_CHARS__

# ── Domínio (subdomínios api.X, db.X, wa.X serão criados) ──
# Domínio configurado: boniweb.com.br
DOMAIN=boniweb.com.br

# ── JWT Secret pro PostgREST (gere com: openssl rand -hex 32) ──
JWT_SECRET=__GERAR_HEX_64_CHARS__

# ── Dashboard administrativo (pgAdmin) ──
ADMIN_EMAIL=admin@boniweb.com.br
ADMIN_PASSWORD=__GERAR_SENHA_FORTE__

# ── Evolution API key (autenticação interna) ──
EVOLUTION_API_KEY=__GERAR_HEX_32_CHARS__
