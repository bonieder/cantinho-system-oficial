# =====================================================
# Cantinho System — Configuração do servidor local
# COPIE este arquivo como .env e edite os valores
# IMPORTANTE: nunca compartilhe o .env publicamente
# =====================================================

# Banco de dados
POSTGRES_DB=cantinho
POSTGRES_USER=cantinho
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE_AQUI_min32chars

# IP do servidor na rede local (descubra com: ip a | grep inet)
# Use o IP fixo que você reservou no roteador
SERVER_HOST=192.168.0.100

# JWT Secret pro PostgREST (gere um com: openssl rand -hex 32)
JWT_SECRET=TROQUE_POR_UMA_CHAVE_HEXADECIMAL_DE_64_CARACTERES

# Dashboard administrativo (pgAdmin)
ADMIN_EMAIL=admin@cantinhodoboni.local
ADMIN_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
